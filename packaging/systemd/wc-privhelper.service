[Unit]
Description=WiFiCatcher privileged radio helper
Documentation=https://github.com/0xPR3ST1JH0NN7/WiFiCatcher
Requires=wc-privhelper.socket
After=wc-privhelper.socket

[Service]
Type=simple
# Started on demand by wc-privhelper.socket, which passes the listening socket
# as fd 3. install-helper.sh fills in the venv python, install dir and app uid.
ExecStart=/opt/wificatcher/.venv/bin/python -m WiFiCatcher.privileged --idle 300 --peer-uid APP_UID
WorkingDirectory=/opt/wificatcher

# Runs as root: airmon-ng/airodump-ng/aireplay-ng and the NetworkManager restart
# need it. The blast radius is bounded by the tiny, validated request surface,
# and by --peer-uid (only the app user's connections are accepted).
User=root

# Light hardening. Kept conservative on purpose: the radio tools touch the
# network stack and system services, so stricter sandboxing (ProtectSystem,
# capability bounding) should be added only after testing on real hardware.
PrivateTmp=true
ProtectHome=true
RestrictAddressFamilies=AF_UNIX AF_NETLINK AF_PACKET
LockPersonality=true

# No [Install]: this unit is socket-activated, not enabled at boot.
